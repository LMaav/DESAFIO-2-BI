<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/cinza_fundo">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detalhes do Carro"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/azul_escuro"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/txtDados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/branco"
        android:padding="16dp"
        android:text="Carregando..."
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/txtCusto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/azul_escuro"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEntrada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registrar Entrada" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registrar Saida" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCalcular"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calcular Custo" />

</LinearLayout>

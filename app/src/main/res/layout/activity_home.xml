<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/cinza_fundo">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Painel do Estacionamento"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/azul_escuro"
        android:layout_marginBottom="16dp" />

    <!-- Resumo: total e livres -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/txtTotalVagas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="16dp"
            android:background="@color/azul"
            android:textColor="@color/branco"
            android:gravity="center"
            android:text="Total: --"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/txtVagasLivres"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="16dp"
            android:background="@color/verde"
            android:textColor="@color/branco"
            android:gravity="center"
            android:text="Livres: --" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Carros estacionados agora:"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Lista em tempo real (RF-10) -->
    <ListView
        android:id="@+id/listaCarros"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/branco" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGerenciarVagas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gerenciar Vagas"
        android:layout_marginTop="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCadastrarCarro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cadastrar Carro" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClientes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clientes" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSair"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sair (logout)" />

</LinearLayout>

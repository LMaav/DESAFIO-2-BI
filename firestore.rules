rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Qualquer usuario autenticado (operador logado) pode ler e escrever.
    // Como todas as telas do app exigem login, isso e suficiente para o desafio.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
